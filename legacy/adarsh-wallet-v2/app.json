{
  "expo": {
    "name": "AdarshWallet",
    "slug": "adarshwallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a8a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.adarsh.wallet",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "AdarshWallet needs microphone access for voice expense entry.",
        "NSSpeechRecognitionUsageDescription": "AdarshWallet uses speech recognition to parse your voice expense entries."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e3a8a"
      },
      "package": "com.adarsh.wallet",
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow AdarshWallet to access your microphone for voice entry."
        }
      ]
    ],
    "scheme": "adarshwallet",
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
